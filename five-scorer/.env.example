# Postgres (Supabase)
# Use the pooled connection string for DATABASE_URL (?pgbouncer=true)
DATABASE_URL="postgresql://postgres:password@localhost:5432/five_scorer?schema=public"
# Direct connection used by prisma migrate (Supabase direct URL)
DIRECT_URL="postgresql://postgres:password@localhost:5432/five_scorer?schema=public"

# PIN hash (bcrypt). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('1234', 10))"
SCORING_PIN_HASH="$2a$10$replace_me_with_your_bcrypt_hash"

# 32+ char secret for iron-session cookie encryption
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
