generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Team {
  A
  B
}

enum MatchStatus {
  LIVE
  FINISHED
}

model Player {
  id        String   @id @default(cuid())
  name      String
  nickname  String?
  isGuest   Boolean  @default(false)
  createdAt DateTime @default(now())

  matches       MatchPlayer[]
  goals         Goal[]        @relation("PlayerGoals")
  assists       Goal[]        @relation("PlayerAssists")
  mvpOfMatches  Match[]       @relation("MatchMvp")

  @@index([name])
}

model Match {
  id         String      @id @default(cuid())
  playedAt   DateTime    @default(now())
  teamAName  String      @default("Équipe A")
  teamBName  String      @default("Équipe B")
  scoreA     Int         @default(0)
  scoreB     Int         @default(0)
  status     MatchStatus @default(LIVE)
  mvpId      String?
  mvp        Player?     @relation("MatchMvp", fields: [mvpId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  players MatchPlayer[]
  goals   Goal[]

  @@index([playedAt])
  @@index([status])
}

model MatchPlayer {
  matchId  String
  playerId String
  team     Team

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([matchId, playerId])
  @@index([playerId])
}

model Goal {
  id        String   @id @default(cuid())
  matchId   String
  scorerId  String
  assistId  String?
  team      Team
  minute    Int?
  createdAt DateTime @default(now())

  match    Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scorer   Player  @relation("PlayerGoals", fields: [scorerId], references: [id], onDelete: Cascade)
  assist   Player? @relation("PlayerAssists", fields: [assistId], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@index([scorerId])
  @@index([assistId])
  @@index([createdAt])
}
